{
 "name": "modalcode",
 "displayName": "ModalCode",
 "version": "0.1.3-dev",
 "author": {
  "name": "Stefano Incardone",
  "email": "stefanoincardone@gmail.com"
 },
 "description": "Adding user-defined modes to VsCode",
 "license": "MIT",
 "repository": {
  "type": "git",
  "url": "https://github.com/StefanoIncardone/ModalCode"
 },

 "categories": ["Keymaps", "Other"],
 "keywords": ["modes"],
 "activationEvents": ["*"],
 "contributes": {
  "configuration": [
   {
    "title": "Modes",
    "properties": {
     "modalcode.modes": {
      "type": "array",
      "description": "List of modes to define",

      "uniqueItems": true,
      "items": {
       "type": "object",
       "description": "Mode properties",

       "required": ["name", "capturing"],
       "additionalProperties": false,
       "properties": {
        "name": {
         "type": "string",
         "description": "The name of the mode",
         "minLength": 1,
         "maxLength": 16
        },
        "capturing": {
         "type": "boolean",
         "description": "Whether the mode should capture typing events",
         "default": false
        }
       }
      }
     }
    }
   }
  ],
  "commands": [
   {
    "category": "ModalCode",
    "title": "Select mode",
    "command": "modalcode.select"
   }
  ]
 },

 "main": "./out/dev/extension.js",
 "scripts": {
   "tsc": "tsc",
   "compile-project": "tsc -p ./ --strict",
   "check": "npm run compile-project -- --noEmit",
   "compile": "npm run compile-project -- --outDir ./out/dev",
   "lint": "eslint ."
 },
 "engineStrict": true,
 "engines": {
   "vscode": "^1.113.0"
 },

 "peerDependencies": {
  "jiti": "2.6.1"
 },
 "devDependencies": {
  "@types/vscode": "1.110.0",
  "typescript": "5.9.3",

  "eslint": "10.1.0",
  "@eslint/js": "10.0.1",
  "typescript-eslint": "8.57.2",
  "@typescript-eslint/eslint-plugin": "8.57.2",
  "@typescript-eslint/parser": "8.57.2",
  "globals": "17.4.0"
 }
}
